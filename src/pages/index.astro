---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { categories, products } from '../data/products';

const featuredProducts = products.filter(p =>
  ['air-filter', 'oil-filter-2', 'fuel-filter', 'hydraulic-pump', 'lift-cylinder', 'multi-valve',
   'brake-master', 'brake-drum', 'steering-unit', 'engine-assembly', 'torque-converter', 'fork-arm']
);
---

<BaseLayout>
  <Header currentPath="/" />

  <!-- Hero Section -->
  <section class="hero">
    <div class="container" style="position:relative;z-index:1;">
      <h1>
        Forklift Parts <span>Expert Supplier</span><br />Hangcha & Heli Specialized
      </h1>
      <p>
        MLIFT — Your trusted source for Hangcha and Heli forklift parts.
        13 product categories, 70+ parts, global shipping with technical support.
      </p>
      <div class="hero-btns">
        <a href="/products" class="btn btn-white">Browse Products</a>
        <a href="/contact" class="btn btn-outline" style="border-color:white;color:white;">Get a Quote</a>
      </div>

      <div class="hero-stats">
        <div class="hero-stat">
          <span class="number">70+</span>
          <span class="label">Parts SKUs</span>
        </div>
        <div class="hero-stat">
          <span class="number">13</span>
          <span class="label">Categories</span>
        </div>
        <div class="hero-stat">
          <span class="number">10+</span>
          <span class="label">Years Exp.</span>
        </div>
        <div class="hero-stat">
          <span class="number">30+</span>
          <span class="label">Countries</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Product Categories</h2>
      <p class="section-subtitle">Full range of Hangcha & Heli forklift parts — one-stop procurement</p>
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/products#${cat.id}`} class="category-card">
            <div class="category-icon">{cat.icon}</div>
            <div class="category-info">
              <h3>{cat.name}</h3>
              <p>{cat.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section" style="background:var(--color-bg-alt);">
    <div class="container">
      <h2 class="section-title">Popular Parts</h2>
      <p class="section-subtitle">Most frequently purchased forklift parts</p>
      <div class="products-grid">
        {featuredProducts.map(p => (
          <div class="product-card">
            <div class="product-image">
              <img src={p.image} alt={p.name} loading="lazy" />
            </div>
            <div class="product-body">
              <h3 class="product-name">{p.name}</h3>
              <p class="product-desc">{p.description}</p>
              <ul class="product-specs">
                {p.specs.slice(0, 2).map(spec => <li>{spec}</li>)}
              </ul>
              <a href="/contact" class="btn btn-outline" style="width:100%;justify-content:center;">Inquire Now</a>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:40px;">
        <a href="/products" class="btn btn-primary">View All 70+ Products →</a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <div>
            <div class="brand-name">MLIFT</div>
            <div class="brand-sub">Forklift Parts Specialist</div>
          </div>
        </div>
        <div class="about-content">
          <h2>Why Choose MLIFT?</h2>
          <p>
            With over a decade of experience in the forklift parts industry, MLIFT is dedicated to supplying
            high-quality parts for Hangcha and Heli forklifts worldwide. We source directly from OEM-approved
            manufacturers to ensure reliable quality and competitive pricing.
          </p>
          <div class="about-features">
            <div class="about-feature">
              <span class="check">✓</span> OEM-Quality Parts
            </div>
            <div class="about-feature">
              <span class="check">✓</span> 13 Product Categories
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Global Shipping
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Technical Support
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Competitive Pricing
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Fast Quotation
            </div>
          </div>
          <div style="margin-top:24px;">
            <a href="/about" class="btn btn-primary">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Need Forklift Parts Quotation?</h2>
      <p>Tell us your requirements — we'll provide an accurate quote within 24 hours.</p>
      <a href="/contact" class="btn btn-white">Get a Quote Now</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
