---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { categories, products } from '../data/products';

const featuredProducts = products.filter(p =>
  ['filter-air', 'filter-oil', 'filter-diesel', 'filter-transmission',
   'brake-master-cylinder', 'brake-drum', 'elec-dashboard', 'engine-assembly',
   'torque-converter', 'hydraulic-gear-pump', 'mast-roller', 'fork-arm']
);
---

<BaseLayout>
  <Header currentPath="/" />

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Quality Forklift Parts<br><span>Ready to Ship Worldwide</span></h1>
        <p>
          MLIFT — your reliable forklift parts partner. 13 categories, 70+ products
          covering engine, transmission, hydraulic, electrical and more. Competitive pricing with fast global delivery.
        </p>
        <div class="hero-btns">
          <a href="/products" class="btn btn-primary">Browse Products</a>
          <a href="/contact" class="btn btn-outline" style="border-color:white;color:white;">Get a Quote</a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <span class="number">70+</span>
            <span class="label">Parts SKUs</span>
          </div>
          <div class="hero-stat">
            <span class="number">13</span>
            <span class="label">Categories</span>
          </div>
          <div class="hero-stat">
            <span class="number">10+</span>
            <span class="label">Years Exp.</span>
          </div>
          <div class="hero-stat">
            <span class="number">30+</span>
            <span class="label">Countries</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section" style="background:var(--color-bg);">
    <div class="container">
      <h2 class="section-title">Product Categories</h2>
      <p class="section-subtitle">Comprehensive range of forklift parts — one-stop procurement solution</p>
      <div class="categories-grid">
        {categories.map(cat => (
          <a href={`/products#${cat.id}`} class="category-card">
            <div class="category-icon">
              <img src={cat.image} alt={cat.name} loading="lazy" />
            </div>
            <div class="category-info">
              <h3>{cat.name}</h3>
              <p>{cat.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section" style="background:var(--color-bg-alt);">
    <div class="container">
      <h2 class="section-title">Popular Parts</h2>
      <p class="section-subtitle">Most frequently purchased forklift components</p>
      <div class="products-grid">
        {featuredProducts.map(p => (
          <div class="product-card">
            <div class="product-image">
              <img src={p.image} alt={p.name} loading="lazy" />
            </div>
            <div class="product-body">
              <h3 class="product-name">{p.name}</h3>
              <div class="product-code">ML#: {p.id}</div>
              <div class="product-spec-line">{p.specs.slice(0, 2).join(' | ')}</div>
              <a href="/contact" class="product-link">Inquire Now →</a>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align:center;margin-top:40px;">
        <a href="/products" class="btn btn-primary">View All 70+ Products →</a>
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-image">
          <div>
            <div class="brand-name">MLIFT</div>
            <div class="brand-sub">Forklift Parts Supplier</div>
          </div>
        </div>
        <div class="about-content">
          <h2>Why Choose MLIFT?</h2>
          <p>
            MLIFT is dedicated to supplying high-quality forklift parts to customers worldwide. We source directly from
            OEM-approved manufacturers, ensuring reliable quality and competitive pricing for every order.
          </p>
          <div class="about-features">
            <div class="about-feature">
              <span class="check">✓</span> OEM-Quality Parts
            </div>
            <div class="about-feature">
              <span class="check">✓</span> 13 Product Categories
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Global Shipping
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Technical Support
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Competitive Pricing
            </div>
            <div class="about-feature">
              <span class="check">✓</span> Fast Quotation
            </div>
          </div>
          <div style="margin-top:24px;">
            <a href="/about" class="btn btn-primary">Learn More →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Need Forklift Parts Quotation?</h2>
      <p>Tell us your requirements — we'll provide an accurate quote within 24 hours.</p>
      <a href="/contact" class="btn btn-white">Get a Quote Now</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
