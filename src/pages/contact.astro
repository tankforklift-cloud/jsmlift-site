---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout>
  <Header currentPath="/contact" />

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="separator">›</span>
        <span>Contact Us</span>
      </div>
      <h1>Contact Us</h1>
      <p>Tell us your requirements — we'll reply within 24 hours</p>
    </div>
  </section>

  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h3>Contact Information</h3>
          <p>
            Welcome to inquire about our forklift parts. Reach us via the channels below,
            or fill out the form to send a direct inquiry.
          </p>

          <div class="contact-item">
            <div class="icon">📧</div>
            <div>
              <strong>Email</strong><br/>
              <span style="color:var(--color-primary);">tan@jsmlift.com</span>
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">🌐</div>
            <div>
              <strong>Website</strong><br/>
              jsmlift.com
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">📍</div>
            <div>
              <strong>Address</strong><br/>
              Jiangsu Province, China
            </div>
          </div>

          <div class="contact-item">
            <div class="icon">🕐</div>
            <div>
              <strong>Business Hours</strong><br/>
              Mon – Fri, 9:00 AM – 6:00 PM (GMT+8)
            </div>
          </div>
        </div>

        <div>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
