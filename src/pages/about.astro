---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header currentPath="/about" />

  <section class="page-header">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="separator">›</span>
        <span>About Us</span>
      </div>
      <h1>About Us</h1>
      <p>Professional forklift parts supplier — Based in China, Serving the World</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section" style="padding-top:20px;">
    <div class="container">
      <div class="about-grid">
        <div class="about-image" style="height:auto;min-height:350px;">
          <div>
            <div class="brand-name">MLIFT</div>
            <div class="brand-sub">SINCE 2015</div>
          </div>
        </div>
        <div class="about-content">
          <h2>MLIFT — Your Trusted Forklift Parts Partner</h2>
          <p>
            MLIFT (JSM LIFT) is a specialized trading company focused on supplying forklift parts for
            major brands worldwide. With over a decade of experience in the forklift parts industry, we have
            accumulated extensive product knowledge and supply chain resources.
          </p>
          <p>
            We understand that the core of forklift parts procurement lies in quality and lead time.
            That's why we've established long-term, stable partnerships with OEM-approved suppliers,
            ensuring all parts we supply meet original factory standards.
          </p>
          <p>
            Whether you need engine parts, transmission systems, hydraulic components, electrical parts,
            or chassis & undercarriage, MLIFT provides a one-stop procurement solution. We serve
            customers across 30+ countries in the Middle East, Central Asia, South America, Africa, and beyond.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service -->
  <section class="section" style="background:var(--color-bg-alt);">
    <div class="container">
      <h2 class="section-title">Our Services</h2>
      <p class="section-subtitle">More than just parts — we're your supply chain partner</p>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🔍</div>
          <h3>Accurate Matching</h3>
          <p>Provide a part number or photo — we'll find the exact matching part for you</p>
        </div>
        <div class="service-card">
          <div class="service-icon">📦</div>
          <h3>Global Logistics</h3>
          <p>Sea, air & express shipping options with door-to-door delivery worldwide</p>
        </div>
        <div class="service-card">
          <div class="service-icon">💰</div>
          <h3>Competitive Pricing</h3>
          <p>Direct from the source — cutting out middlemen to save you money</p>
        </div>
        <div class="service-card">
          <div class="service-icon">🛡️</div>
          <h3>Quality Guarantee</h3>
          <p>Rigorous pre-shipment inspection with up to 12-month warranty</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
